local function createSlider(text, min, max, default, configKey, targetTable, parent, callback)
    local container = Instance.new("Frame")
    container.Name = "FRH_Slider_" .. text
    container.Size = UDim2.new(1, 0, 0, 45)
    container.BackgroundColor3 = BG_CARD
    container.BorderSizePixel = 0
    container.Parent = parent
    local label = Instance.new("TextLabel")
    label.Name = "FRH_SliderLabel"
    label.Size = UDim2.new(0.6, 0, 0, 18)
    label.Position = UDim2.new(0, 6, 0, 2)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = TEXT_WHITE
    label.Font = Enum.Font.Gotham
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = container
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Name = "FRH_SliderValue"
    valueLabel.Size = UDim2.new(0.2, 0, 0, 18)
    valueLabel.Position = UDim2.new(0.8, -20, 0, 2)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Text = tostring(default)
    valueLabel.TextColor3 = PURPLE
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextSize = 12
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.Parent = container
    local slideBar = Instance.new("TextButton")
    slideBar.Name = "FRH_SliderBar"
    slideBar.Size = UDim2.new(1, -12, 0, 4)
    slideBar.Position = UDim2.new(0, 6, 0, 30)
    slideBar.BackgroundColor3 = Color3.fromRGB(30, 41, 59)
    slideBar.Text = ""
    slideBar.Parent = container
    local fill = Instance.new("Frame")
    fill.Name = "FRH_SliderFill"
    fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = PURPLE
    fill.BorderSizePixel = 0
    fill.Parent = slideBar
    local sliding = false
    local function updateSlider(input)
        local xPercent = math.clamp((input.Position.X - slideBar.AbsolutePosition.X) / slideBar.AbsoluteSize.X, 0, 1)
        local newValue = math.round((min + (xPercent * (max - min))) * 10) / 10
        if newValue > max then newValue = max end
        fill.Size = UDim2.new(xPercent, 0, 1, 0)
        valueLabel.Text = tostring(newValue)
        targetTable[configKey] = newValue
        if callback then callback(newValue) end
        SalvarConfiguracoes()
    end
    slideBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = true
            updateSlider(input)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(input)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = false
        end
    end)
    return container
end

