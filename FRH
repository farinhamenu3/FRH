local function startTPKill()
    if tpKillRunning then return end
    tpKillRunning = true
    tpKillTask = task.spawn(function()
        while tpKillRunning and MicsConfig.TPKill do
            task.wait(TPKILL_INTERVAL)
            if not tpKillRunning or not MicsConfig.TPKill then break end
            local targets = {}
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= player and p.Character then
                    local char = p.Character
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    local humanoid = char:FindFirstChild("Humanoid")
                    if hrp and humanoid and humanoid.Health > 0 and not Whitelist[p.Name] and not isInSafeZone(hrp.Position) then
                        table.insert(targets, {hrp = hrp, player = p})
                    end
                end
            end
            if #targets > 0 then
                local target = targets[math.random(1, #targets)]
                local myChar = player.Character
                local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
                if myHRP and target.hrp then
                    local oldCanCollide = myHRP.CanCollide
                    myHRP.CanCollide = false
                    myHRP.CFrame = target.hrp.CFrame + Vector3.new(0, 2, 0)
                    task.wait(0.1)
                    myHRP.CanCollide = oldCanCollide
                    print("TPKILL: Teleportado para " .. target.player.Name)
                end
            end
        end
    end)
end

local function stopTPKill()
    tpKillRunning = false
    if tpKillTask then task.cancel(tpKillTask); tpKillTask = nil end
    print("TPKILL DESATIVADO")
end

