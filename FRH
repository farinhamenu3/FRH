local function setupSilentAimHook(tool)
    pcall(function()
        if not tool or not tool:IsA("Tool") then return end
        if silentAimHooks[tool] then return end

        local fireRemote = tool:FindFirstChild("FireRemote") or tool:FindFirstChild("ShootRemote") or tool:FindFirstChild("RemoteEvent")
        if fireRemote and fireRemote:IsA("RemoteEvent") then
            local originalFunction = fireRemote.OnClientEvent
            local connection
            connection = fireRemote.OnClientEvent:Connect(function(...)
                if AimbotConfig.SilentAim and silentAimTarget then
                    local args = {...}
                    if args[1] and typeof(args[1]) == "CFrame" then
                        args[1] = CFrame.new(silentAimTarget.position)
                    elseif args[1] and typeof(args[1]) == "Vector3" then
                        args[1] = silentAimTarget.position
                    end
                    fireRemote:FireServer(unpack(args))
                    return
                end
                if originalFunction then originalFunction(...) end
            end)
            silentAimHooks[tool] = connection
        end

        local activatedConnection
        activatedConnection = tool.Activated:Connect(function()
            if AimbotConfig.SilentAim and silentAimTarget then
                local mouse = player:GetMouse()
                if mouse then
                    local originalHit = mouse.Hit
                    mouse.Hit = CFrame.new(silentAimTarget.position)
                    task.wait(0)
                    mouse.Hit = originalHit
                end
            end
        end)
        silentAimHooks[tool] = {remote = silentAimHooks[tool], activated = activatedConnection}
    end)
end

local function applySilentAimHooks()
    pcall(function()
        local char = player.Character
        if char then
            for _, tool in pairs(char:GetChildren()) do
                if tool:IsA("Tool") then setupSilentAimHook(tool) end
            end
        end
        local backpack = player:FindFirstChild("Backpack")
        if backpack then
            for _, tool in pairs(backpack:GetChildren()) do
                if tool:IsA("Tool") then setupSilentAimHook(tool) end
            end
        end
    end)
end

