    bindBtn.Parent = container

    local bindBtnCorner = Instance.new("UICorner")
    bindBtnCorner.CornerRadius = UDim.new(0, 4)
    bindBtnCorner.Parent = bindBtn

    bindBtn.MouseButton1Click:Connect(function()
        if waitingForBind then
            waitingForBind = false
            waitingForBindType = ""
            bindBtn.Text = "BIND"
            bindBtn.BackgroundColor3 = PURPLE
            return
        end

        waitingForBind = true
        waitingForBindType = configKey
        bindBtn.Text = "AGUARDANDO..."
        bindBtn.BackgroundColor3 = Color3.fromRGB(239, 68, 68)

        local function processBindKey(input)
            if not waitingForBind or waitingForBindType ~= configKey then return end
            local bindValue = nil
            if input.UserInputType == Enum.UserInputType.Keyboard then
                bindValue = input.KeyCode
            elseif input.UserInputType == Enum.UserInputType.MouseButton1 or
                   input.UserInputType == Enum.UserInputType.MouseButton2 or
                   input.UserInputType == Enum.UserInputType.MouseButton3 then
                bindValue = input.UserInputType
            else
                return
            end
            if bindValue == Enum.KeyCode.Unknown then return end

            targetTable[configKey] = bindValue
            keyLabel.Text = tostring(bindValue):gsub("Enum.KeyCode.", ""):gsub("Enum.UserInputType.", "")
            waitingForBind = false
            waitingForBindType = ""
            bindBtn.Text = "BIND"
            bindBtn.BackgroundColor3 = PURPLE
            if callback then callback(bindValue) end
            SalvarConfiguracoes()
        end

        local connection
        connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            processBindKey(input)
            if not waitingForBind then
                connection:Disconnect()
            end
        end)
    end)

    return container
end

