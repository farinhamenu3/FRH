local function forceInfiniteAmmo()
    pcall(function()
        local char = player.Character
        local function processTool(tool)
            if not tool or not tool:IsA("Tool") then return end
            for _, obj in pairs(tool:GetDescendants()) do
                local name = string.lower(obj.Name)
                if name:find("ammo") or name:find("clip") or name:find("mag") or name:find("bullet") or name:find("munition") then
                    if obj:IsA("NumberValue") or obj:IsA("IntValue") then
                        if obj.Value < 999 then obj.Value = 999 end
                    end
                end
            end
        end
        if char then
            for _, tool in pairs(char:GetChildren()) do
                if tool:IsA("Tool") then processTool(tool) end
            end
        end
        local backpack = player:FindFirstChild("Backpack")
        if backpack then
            for _, tool in pairs(backpack:GetChildren()) do
                if tool:IsA("Tool") then processTool(tool) end
            end
        end
    end)
end

local function applyWeaponMods(tool)
    pcall(function()
        if not tool or not tool:IsA("Tool") then return end

        if MicsConfig.NoRecoil then
            for _, obj in pairs(tool:GetDescendants()) do
                local name = string.lower(obj.Name)
                if name:find("recoil") or name:find("kick") or name:find("shake") then
                    if obj:IsA("NumberValue") or obj:IsA("IntValue") then obj.Value = 0 end
                    if obj:IsA("Vector3Value") then obj.Value = Vector3.zero end
                end
            end
        end

        if MicsConfig.NoSpread then
            for _, obj in pairs(tool:GetDescendants()) do
                local name = string.lower(obj.Name)
                if name:find("spread") or name:find("accuracy") or name:find("inaccuracy") then
                    if obj:IsA("NumberValue") or obj:IsA("IntValue") then obj.Value = 0 end
                end
            end
        end

        if MicsConfig.InfiniteAmmo or (MicsConfig.ModoV and modoVActive) then
            for _, obj in pairs(tool:GetDescendants()) do
                local name = string.lower(obj.Name)
                if name:find("ammo") or name:find("clip") or name:find("mag") or name:find("bullet") or name:find("munition") then
                    if obj:IsA("NumberValue") or obj:IsA("IntValue") then
                        if obj.Value < 999 then obj.Value = 999 end
                    end
                end
            end
        end

        if MicsConfig.AutoReload then
            for _, obj in pairs(tool:GetDescendants()) do
                if obj:IsA("NumberValue") and string.lower(obj.Name):find("ammo") and obj.Value == 0 then
                    local reloadRemote = tool:FindFirstChild("ReloadRemote")
                    if reloadRemote and reloadRemote:IsA("RemoteEvent") then
                        reloadRemote:FireServer()
                    end
                    local char = player.Character
                    if char then
                        local humanoid = char:FindFirstChild("Humanoid")
                        if humanoid then
                            humanoid:SetStateEnabled(Enum.HumanoidStateType.Climbing, false)
                            humanoid:SetStateEnabled(Enum.HumanoidStateType.Climbing, true)
                        end
                    end
                end
            end
        end
    end)
end

task.spawn(function()
    while task.wait(0.3) do
        pcall(function()
            local char = player.Character
            if char then
                for _, tool in pairs(char:GetChildren()) do
