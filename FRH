-- ============================================================
-- LOOP PRINCIPAL (AIMBOT + SILENT AIM + ESP COM SKELETON CORRIGIDO)
-- ============================================================
local LastCameraRotation = camera.CFrame.Rotation
local CurrentTarget = nil

RunService.RenderStepped:Connect(function()
    pcall(function()
        -- FOV CIRCULO PERFEITO
        FOVCircle.Visible = AimbotConfig.ShowFOV and screenGui.Enabled
        FOVCircle.Radius = AimbotConfig.FOVSize
        FOVCircle.Position = UserInputService:GetMouseLocation()
        FOVCircle.Color = AimbotConfig.FOVColor
        FOVCircle.Transparency = 1
        FOVCircle.Thickness = 2
        FOVCircle.NumSides = 80

        if MicsConfig.NoRecoil then
            if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                camera.CFrame = CFrame.new(camera.CFrame.Position) * LastCameraRotation
            else
                LastCameraRotation = camera.CFrame.Rotation
            end
        end

        -- SILENT AIM
        if AimbotConfig.SilentAim and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
            local targets = {}
            local mousePos = UserInputService:GetMouseLocation()
            
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= player and p.Character and not Whitelist[p.Name] then
                    local char = p.Character
                    local humanoid = char:FindFirstChild("Humanoid")
                    if humanoid and humanoid.Health > 0 then
                        if not AimbotConfig.TeamCheck or p.Team ~= player.Team then
                            local targetPart = nil
                            if AimbotConfig.TargetPart == "Head" then
                                targetPart = char:FindFirstChild("Head")
                            elseif AimbotConfig.TargetPart == "Torso" then
                                targetPart = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
                            elseif AimbotConfig.TargetPart == "Pelvis" then
                                targetPart = char:FindFirstChild("LowerTorso") or char:FindFirstChild("HumanoidRootPart")
                            end
                            if not targetPart then targetPart = char:FindFirstChild("HumanoidRootPart") end
                            
                            if targetPart then
                                local pos, onScreen = camera:WorldToViewportPoint(targetPart.Position)
                                if onScreen then
                                    local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                                    if dist < AimbotConfig.FOVSize then
                                        table.insert(targets, {
                                            part = targetPart,
                                            position = targetPart.Position,
                                            dist = dist,
                                            screenPos = Vector2.new(pos.X, pos.Y)
                                        })
                                    end
                                end
                            end
                        end
                    end
                end
            end
            
            table.sort(targets, function(a, b) return a.dist < b.dist end)
            
            if #targets > 0 then
                local target = targets[1]
                if AimbotConfig.WallCheck then
                    local origin = camera.CFrame.Position
                    local direction = (target.position - origin).Unit * (target.position - origin).Magnitude
                    local raycastParams = RaycastParams.new()
                    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
                    raycastParams.FilterDescendantsInstances = {player.Character}
                    local result = workspace:Raycast(origin, direction, raycastParams)
                    if result then
                        local hitPart = result.Instance
                        if hitPart and hitPart:IsDescendantOf(target.part.Parent) then
                            silentAimTarget = target
                            camera.CFrame = CFrame.new(camera.CFrame.Position, target.position)
                            LastCameraRotation = camera.CFrame.Rotation
                        end
                    end
                else
                    silentAimTarget = target
                    camera.CFrame = CFrame.new(camera.CFrame.Position, target.position)
                    LastCameraRotation = camera.CFrame.Rotation
                end
            else
                silentAimTarget = nil
            end
        else
            if not AimbotConfig.Enabled then silentAimTarget = nil end
        end

        -- AIMBOT NORMAL
        if AimbotConfig.Enabled and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            if not CurrentTarget or not CurrentTarget.Parent or not CurrentTarget.Parent:FindFirstChildOfClass("Humanoid") or CurrentTarget.Parent:FindFirstChildOfClass("Humanoid").Health <= 0 then
                local targets = {}
                local mousePos = UserInputService:GetMouseLocation()
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= player and p.Character and not Whitelist[p.Name] then
                        local char = p.Character
                        local humanoid = char:FindFirstChild("Humanoid")
                        if humanoid and humanoid.Health > 0 then
                            if not AimbotConfig.TeamCheck or p.Team ~= player.Team then
                                local targetPart = nil
                                if AimbotConfig.TargetPart == "Head" then
                                    targetPart = char:FindFirstChild("Head")
                                elseif AimbotConfig.TargetPart == "Torso" then
                                    targetPart = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
                                elseif AimbotConfig.TargetPart == "Pelvis" then
                                    targetPart = char:FindFirstChild("LowerTorso") or char:FindFirstChild("HumanoidRootPart")
                                end
                                if not targetPart then targetPart = char:FindFirstChild("HumanoidRootPart") end
                                if targetPart then
                                    local pos, onScreen = camera:WorldToViewportPoint(targetPart.Position)
                                    if onScreen then
                                        local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                                        if dist < AimbotConfig.FOVSize then
                                            table.insert(targets, {part = targetPart, pos = targetPart.Position, dist = dist})
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
                table.sort(targets, function(a, b) return a.dist < b.dist end)
                if #targets > 0 then
                    CurrentTarget = targets[1]
                else
                    CurrentTarget = nil
                end
            end
            if CurrentTarget then
                local smoothFactor = AimbotConfig.Smoothness / 30
                if smoothFactor < 0.03 then smoothFactor = 0.03 end
                local targetCFrame = CFrame.new(camera.CFrame.Position, CurrentTarget.pos)
                camera.CFrame = camera.CFrame:Lerp(targetCFrame, smoothFactor)
                LastCameraRotation = camera.CFrame.Rotation
            end
        else
            CurrentTarget = nil
        end

        -- ESP DRAWING (COM SKELETON CORRIGIDO)
        for _, p in pairs(Players:GetPlayers()) do
            local vis = ESP[p]
            if not vis then continue end

            -- Reseta todas as visibilidades
            for _, c in pairs(vis.Corners) do c.Visible = false end
            for _, b in pairs(vis.Bones) do b.Visible = false end
            vis.Box.Visible = false
            vis.Tracer.Visible = false
            vis.Name.Visible = false
            vis.Distance.Visible = false

            local char = p.Character
            if char and p ~= player then
                if AimbotConfig.TeamCheck and p.Team == player.Team then
                    continue
                end
                if Whitelist[p.Name] then
                    continue
                end
                
                local root = char:FindFirstChild("HumanoidRootPart")
                local hum = char:FindFirstChildOfClass("Humanoid")
                local head = char:FindFirstChild("Head")
                
                if root and hum and hum.Health > 0 and head then
                    local rPos, onScreen = camera:WorldToViewportPoint(root.Position)
                    if onScreen then
                        local isVisible = IsVisible(head, char)
                        local corDinamica = isVisible and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)

                        local topY = camera:WorldToViewportPoint(root.Position + Vector3.new(0, 3, 0)).Y
                        local botY = camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0)).Y
                        local h = math.abs(topY - botY)
                        local w = h * 0.6
                        local x = rPos.X - (w/2)

                        -- CORNER 2D
                        if VisualConfig.Corner2D then
                            local tl, tl2, tr, tr2, bl, bl2, br, br2 = vis.Corners[1], vis.Corners[2], vis.Corners[3], vis.Corners[4], vis.Corners[5], vis.Corners[6], vis.Corners[7], vis.Corners[8]
                            local len = w / 4
                            if tl and tl2 and tr and tr2 and bl and bl2 and br and br2 then
                                tl.From = Vector2.new(x, topY); tl.To = Vector2.new(x + len, topY); tl.Color = corDinamica; tl.Visible = true
                                tl2.From = Vector2.new(x, topY); tl2.To = Vector2.new(x, topY + len); tl2.Color = corDinamica; tl2.Visible = true
                                tr.From = Vector2.new(x + w, topY); tr.To = Vector2.new(x + w - len, topY); tr.Color = corDinamica; tr.Visible = true
                                tr2.From = Vector2.new(x + w, topY); tr2.To = Vector2.new(x + w, topY + len); tr2.Color = corDinamica; tr2.Visible = true
                                bl.From = Vector2.new(x, topY + h); bl.To = Vector2.new(x + len, topY + h); bl.Color = corDinamica; bl.Visible = true
                                bl2.From = Vector2.new(x, topY + h); bl2.To = Vector2.new(x, topY + h - len); bl2.Color = corDinamica; bl2.Visible = true
                                br.From = Vector2.new(x + w, topY + h); br.To = Vector2.new(x + w - len, topY + h); br.Color = corDinamica; br.Visible = true
                                br2.From = Vector2.new(x + w, topY + h); br2.To = Vector2.new(x + w, topY + h - len); br2.Color = corDinamica; br2.Visible = true
                            end
                        end

                        -- BOX ESP
                        if VisualConfig.BoxESP then
                            vis.Box.Size = Vector2.new(w, h)
                            vis.Box.Position = Vector2.new(x, topY)
                            vis.Box.Color = corDinamica
                            vis.Box.Visible = true
                        end

                        -- TRACERS
                        if VisualConfig.ShowTracers then
                            local tracerYPos = camera.ViewportSize.Y
                            if VisualConfig.TracersPosition == "Em cima" then
                                tracerYPos = 0
                            end
                            vis.Tracer.From = Vector2.new(camera.ViewportSize.X/2, tracerYPos)
                            vis.Tracer.To = Vector2.new(rPos.X, rPos.Y)
                            vis.Tracer.Color = VisualConfig.LinesColor
                            vis.Tracer.Visible = true
                        end

                        -- NOME
                        if VisualConfig.ShowName then
                            vis.Name.Text = p.Name
                            local yOff = VisualConfig.NamePosition == "Head" and -20 or h + 15
                            vis.Name.Position = Vector2.new(rPos.X, topY + yOff)
                            vis.Name.Color = VisualConfig.NameColor
                            vis.Name.Visible = true
                        end

                        -- DISTÂNCIA
                        if VisualConfig.ShowDistance then
                            local dist = math.floor((root.Position - camera.CFrame.Position).Magnitude)
                            vis.Distance.Text = dist .. "m"
                            local yOff = VisualConfig.DistancePosition == "Head" and -35 or h + 30
                            vis.Distance.Position = Vector2.new(rPos.X, topY + yOff)
                            vis.Distance.Color = VisualConfig.DistanceColor
                            vis.Distance.Visible = true
                        end

                        -- ============================================================
                        -- SKELETON ESP CORRIGIDO
                        -- ============================================================
                        if VisualConfig.SkeletonESP then
                            local bIdx = 1
                            local skeletonColor = VisualConfig.SkeletonColor
                            
                            -- Coleta todas as partes disponíveis do personagem
                            local parts = {}
                            for _, child in pairs(char:GetChildren()) do
                                if child:IsA("BasePart") then
                                    parts[child.Name] = child
                                end
                            end
                            parts["HumanoidRootPart"] = root
                            
                            -- Desenha cada par de ossos
                            for _, pair in pairs(bonePairs) do
                                local partA = parts[pair[1]]
                                local partB = parts[pair[2]]
                                
                                if partA and partB and vis.Bones[bIdx] then
                                    local posA, onScreenA = camera:WorldToViewportPoint(partA.Position)
                                    local posB, onScreenB = camera:WorldToViewportPoint(partB.Position)
                                    
                                    if onScreenA and onScreenB then
                                        vis.Bones[bIdx].From = Vector2.new(posA.X, posA.Y)
                                        vis.Bones[bIdx].To = Vector2.new(posB.X, posB.Y)
                                        vis.Bones[bIdx].Color = skeletonColor
                                        vis.Bones[bIdx].Thickness = 2
                                        vis.Bones[bIdx].Visible = true
                                        bIdx = bIdx + 1
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end)
end)

