local function CreateESPVisuals(p)
    if ESP[p] then return end
    local objs = {
        Box = Drawing.new("Square"),
        Tracer = Drawing.new("Line"),
        Name = Drawing.new("Text"),
        Distance = Drawing.new("Text"),
        Bones = {},
        Corners = {}
    }
    objs.Box.Thickness = 1; objs.Box.Filled = false; objs.Box.Visible = false
    objs.Tracer.Thickness = 1; objs.Tracer.Visible = false
    objs.Name.Size = 13; objs.Name.Center = true; objs.Name.Outline = true; objs.Name.Visible = false
    objs.Distance.Size = 11; objs.Distance.Center = true; objs.Distance.Outline = true; objs.Distance.Visible = false
    
    -- Cria 30 linhas para os ossos (mais que o necessário)
    for i = 1, 30 do
        objs.Bones[i] = Drawing.new("Line")
        objs.Bones[i].Thickness = 2
        objs.Bones[i].Visible = false
    end
    
    for i = 1, 8 do
        objs.Corners[i] = Drawing.new("Line")
        objs.Corners[i].Thickness = 1
        objs.Corners[i].Visible = false
    end
    ESP[p] = objs
end

local function RemoveESPVisuals(p)
    if ESP[p] then
        pcall(function()
            for _, obj in pairs(ESP[p]) do
                if type(obj) == "table" then
                    for _, s in pairs(obj) do s:Remove() end
                else
                    obj:Remove()
                end
            end
        end)
        ESP[p] = nil
    end
end

Players.PlayerAdded:Connect(function(p)
    CreateESPVisuals(p)
    p.CharacterAdded:Connect(function()
        if ESP[p] then RemoveESPVisuals(p) end
        CreateESPVisuals(p)
    end)
end)
Players.PlayerRemoving:Connect(RemoveESPVisuals)
for _, p in pairs(Players:GetPlayers()) do CreateESPVisuals(p) end

local function IsVisible(part, character)
    local origin = camera.CFrame.Position
    local direction = (part.Position - origin).Unit * (part.Position - origin).Magnitude
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.FilterDescendantsInstances = {player.Character}
    local result = workspace:Raycast(origin, direction, raycastParams)
    if result then
        local hitPart = result.Instance
        if hitPart and hitPart:IsDescendantOf(character) then return true end
        return false
    end
    return true
end

