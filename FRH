local function PuxarItemUnico(item)
    if not item or not item.Parent then return false end
    local character = player.Character
    if not character then return false end
    local sucesso = false
    if item:IsA("Tool") then
        if item.Parent == character then return false end
        pcall(function()
            local backpack = player:FindFirstChildOfClass("Backpack")
            if backpack then item.Parent = backpack; sucesso = true end
        end)
        if not sucesso then pcall(function() item.Parent = character; sucesso = true end) end
    end
    if not sucesso and item:IsA("BasePart") then
        local cd = item:FindFirstChild("ClickDetector")
        if cd then pcall(function() cd:Click() end); sucesso = true end
    end
    if not sucesso then
        for _, prompt in pairs(item:GetChildren()) do
            if prompt:IsA("ProximityPrompt") then pcall(function() prompt:Prompt() end); sucesso = true; break end
        end
    end
    if not sucesso then
        for _, prompt in pairs(item:GetDescendants()) do
            if prompt:IsA("ProximityPrompt") then pcall(function() prompt:Prompt() end); sucesso = true; break end
        end
    end
    return sucesso
end

local function isPuxavel(item)
    if not item then return false end
    if item:IsA("Tool") then
        local owner = item.Parent
        if owner == player.Character then return false end
        if owner and owner:IsA("Backpack") and owner.Parent == player then return false end
        return true
    end
    if item:IsA("BasePart") and item:FindFirstChild("ClickDetector") then return true end
    if item:FindFirstChildWhichIsA("ProximityPrompt") then return true end
    if item:IsA("Model") then
        if item:FindFirstChild("Handle") then return true end
        if item:FindFirstChildWhichIsA("Tool") then return true end
        if item:FindFirstChild("ClickDetector") then return true end
        if item:FindFirstChildWhichIsA("ProximityPrompt") then return true end
    end
    return false
end

task.spawn(function()
    local puxadosCache = {}
    while task.wait(0.5) do
        if not MicsConfig.PuxarArmas then puxadosCache = {} continue end
        pcall(function()
            local character = player.Character
            local root = character and character:FindFirstChild("HumanoidRootPart")
            if not root then return end
            local distanciaMax = MicsConfig.DistanciaPuxar
            local itemsPuxados = {}
            for _, item in pairs(workspace:GetDescendants()) do
                if isPuxavel(item) then
                    local itemPos = nil
                    if item:IsA("BasePart") then itemPos = item.Position
                    elseif item:IsA("Tool") then
                        local handle = item:FindFirstChild("Handle")
                        if handle and handle:IsA("BasePart") then itemPos = handle.Position
                        else
                            local part = item:FindFirstChildWhichIsA("BasePart")
                            if part then itemPos = part.Position end
                        end
                    elseif item:IsA("Model") then
                        local handle = item:FindFirstChild("Handle")
                        if handle and handle:IsA("BasePart") then itemPos = handle.Position
                        else
                            local part = item:FindFirstChildWhichIsA("BasePart")
                            if part then itemPos = part.Position end
                        end
                    end
                    if itemPos then
                        local distancia = (root.Position - itemPos).Magnitude
                        if distancia < distanciaMax then
                            local parent = item.Parent
                            if parent ~= character and parent ~= player and parent ~= player.Character then
                                local isInHand = false
                                if parent and parent:IsA("Model") and parent:FindFirstChild("Humanoid") then isInHand = true end
                                if not isInHand then table.insert(itemsPuxados, item) end
                            end
                        end
                    end
                end
            end
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= player then
                    local backpack = p:FindFirstChildOfClass("Backpack")
                    if backpack then
                        for _, tool in pairs(backpack:GetChildren()) do
                            if tool:IsA("Tool") then
                                local targetChar = p.Character
                                local targetRoot = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
                                if targetRoot then
                                    local distancia = (root.Position - targetRoot.Position).Magnitude
                                    if distancia < distanciaMax then table.insert(itemsPuxados, tool) end
                                end
                            end
                        end
                    end
                    local targetChar = p.Character
                    if targetChar then
                        for _, tool in pairs(targetChar:GetChildren()) do
                            if tool:IsA("Tool") then
                                local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
                                if targetRoot then
                                    local distancia = (root.Position - targetRoot.Position).Magnitude
                                    if distancia < distanciaMax then table.insert(itemsPuxados, tool) end
                                end
                            end
                        end
                    end
                end
            end
            for _, item in pairs(itemsPuxados) do
                if item and item.Parent then
                    local itemId = tostring(item)
                    if not puxadosCache[itemId] then
                        local sucesso = PuxarItemUnico(item)
                        if sucesso then
                            puxadosCache[itemId] = true
                            task.spawn(function()
                                task.wait(0.5)
                                puxadosCache[itemId] = nil
                            end)
                        end
                    end
                end
            end
            for key, _ in pairs(puxadosCache) do
                local found = false
                for _, item in pairs(itemsPuxados) do
                    if tostring(item) == key then found = true; break end
                end
                if not found then puxadosCache[key] = nil end
            end
        end)
    end
end)

